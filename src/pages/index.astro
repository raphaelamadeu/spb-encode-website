---
import "../styles/global.css";
import Nav from '../components/nav.astro';
import Block from  '../components/block.astro';

import Editor from "../react/editor.jsx";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
      <title>spB Encode - Sparkplug B Payload Encoder & Decoder</title>
    <meta name="description" content="Encode and decode Sparkplug B payloads with spB Encode. A fast, reliable tool for working with MQTT Sparkplug B data.">
    <meta name="keywords" content="Sparkplug B, MQTT, payload encoder, payload decoder, IIoT, industrial IoT, spBv1.0, data encoding, telemetry">
    <meta name="author" content="spB Encode">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="spB Encode - Sparkplug B Payload Encoder & Decoder">
    <meta property="og:description" content="Quickly encode and decode Sparkplug B payloads for MQTT and IIoT applications.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://spbencode.netlify.com">
    <meta property="og:image" content="https://spbencode.com/og-image.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="google-site-verification" content="LMEUmDmvqBwty7hjCcNlZL6wJFeOU1VpkvRtjIJvK-U" />
	</head>
	<body class="bg-neutral-900 text-white">
    <Nav></Nav>
    <div class="mx-auto max-w-7xl my-8 sm:px-6 lg:px-8">
      <Block suppressHydrationWarning={true}>
        <Editor client:load/>
      </Block>
      <div class="flex justify-center my-8">
      <a href="https://www.buymeacoffee.com/raphaelmax" target="_blank"><img src="https://cdn.buymeacoffee.com/buttons/v2/default-yellow.png" alt="Buy Me a Coffee" style="height: 60px !important;width: 217px !important;" ></a>
      </div>
    </div>
	</body>
</html>
